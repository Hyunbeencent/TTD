// --- Helper Functions ---
const getAbsDate = (dateStr) => {
  if (!dateStr || dateStr === "TBD" || dateStr === "N/A" || dateStr === "-" || dateStr.trim() === "") return null;
  if (dateStr.includes('/')) {
    const parts = dateStr.split('/');
    if (parts.length === 3) {
      let month = parseInt(parts[0]) - 1;
      let day = parseInt(parts[1]);
      let year = parseInt(parts[2]);
      if (year < 100) year += 2000;
      return new Date(year, month, day);
    }
  }
  if (/^\d{4}-\d{2}-\d{2}$/.test(dateStr)) return new Date(dateStr);
  const d = new Date(dateStr);
  return isNaN(d.getTime()) ? null : d;
};

const formatDisplayDate = (dateStr) => {
  const d = getAbsDate(dateStr);
  if (!d) return dateStr || "N/A";
  return `${String(d.getDate()).padStart(2, '0')}-${String(d.getMonth() + 1).padStart(2, '0')}`;
};

const toYMD = (dateStr) => {
  const d = getAbsDate(dateStr);
  if (!d) return "";
  return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
};

const getStatusColor = (status) => {
  switch (status) {
    case 'Done': return '#10b981';
    case 'on track': return '#3b82f6';
    case 'delayed': return '#ef4444';
    case 'Hold': return '#f59e0b';
    case 'Failed': return '#0f172a';
    case 'Canceled': return '#94a3b8';
    default: return '#cbd5e1';
  }
};

