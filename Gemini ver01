    const unsubscribe = onSnapshot(tasksCollection, 
      (snapshot) => {
        const data = snapshot.docs.map(doc => ({ ...doc.data(), id: doc.id }));
        setTasks(data);
        setLoading(false);
      },
      (error) => {
