  // --- 3. UI Fixes: Admin Scroll ---
  useEffect(() => {
    if (isAdmin) {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }
  }, [isAdmin]);

  // --- 4. Logic & Calculations ---
  const computedTasks = useMemo(() => {
    return tasks.map(task => {
      let status = (task.status === "Finished" || task.status === "Done") ? "Done" : task.status;
      const isManual = ["Done", "Hold", "Failed", "Canceled"].includes(status);
      const dueDateObj = getAbsDate(task.dueDate);
      if (!isManual) {
        if (dueDateObj && dueDateObj < TODAY) status = "delayed";
        else status = "on track";
      }
      const assigned = getAbsDate(task.assignedDate);
      const finished = getAbsDate(task.finishDate);
      let calcDays = 0;
      if (assigned) {
        if (["Done", "Failed", "Canceled"].includes(status)) {
          calcDays = finished ? Math.floor((finished - assigned) / (1000 * 60 * 60 * 24)) : Math.floor((TODAY - assigned) / (1000 * 60 * 60 * 24));
        } else {
          calcDays = Math.floor((TODAY - assigned) / (1000 * 60 * 60 * 24));
        }
      }
      return { ...task, displayStatus: status, calcDaysLapsed: Math.max(0, calcDays) };
    });
  }, [tasks]);

  const globalOwnerStats = useMemo(() => {
    const statsMap = {};
    const openStatuses = ['on track', 'delayed', 'Hold'];
    const closedStatuses = ['Done', 'Failed', 'Canceled'];
    computedTasks.forEach(task => {
      const owners = task.owner?.split(/[&,/]/).map(o => o.trim()) || [];
      const isOpen = openStatuses.includes(task.displayStatus);
      const isClosed = closedStatuses.includes(task.displayStatus);
      owners.forEach(o => {
        if (o && o !== "\\" && o !== "-" && o !== "Assignee") {
          if (!statsMap[o]) statsMap[o] = { total: 0, open: 0, closed: 0, totalDaysLapsed: 0, avgLeadTime: 0 };
          statsMap[o].total += 1;
          statsMap[o].totalDaysLapsed += (task.calcDaysLapsed || 0);
          if (isClosed) statsMap[o].closed += 1;
          else if (isOpen) statsMap[o].open += 1;
        }
      });
    });
    Object.keys(statsMap).forEach(name => {
      const data = statsMap[name];
      data.avgLeadTime = data.total > 0 ? Math.round(data.totalDaysLapsed / data.total) : 0;
    });
    return statsMap;
  }, [computedTasks]);

  const sortedAndFilteredTasks = useMemo(() => {
    let items = computedTasks.filter(task => {
      const matchesSearch = task.item?.toLowerCase().includes(searchTerm.toLowerCase()) || task.owner?.toLowerCase().includes(searchTerm.toLowerCase()) || String(task.id).includes(searchTerm);
      const matchesStatus = selectedStatuses.length === 0 || selectedStatuses.includes(task.displayStatus);
      const matchesOwner = selectedOwners.length === 0 || selectedOwners.some(o => task.owner?.toLowerCase().includes(o.toLowerCase()));
      const matchPersonalView = selectedUserView ? task.owner?.split(/[&,/]/).map(n => n.trim()).includes(selectedUserView) : true;
      return matchesSearch && matchesStatus && matchesOwner && matchPersonalView;
    });
    if (sortConfig.direction) {
      items.sort((a, b) => {
        let aVal, bVal;
        switch (sortConfig.key) {
          case 'id': aVal = Number(a.id); bVal = Number(b.id); break;
          case 'assignedDate': aVal = getAbsDate(a.assignedDate)?.getTime() || 0; bVal = getAbsDate(b.assignedDate)?.getTime() || 0; break;
          case 'dueDate': aVal = getAbsDate(a.dueDate)?.getTime() || 0; bVal = getAbsDate(b.dueDate)?.getTime() || 0; break;
          case 'timeline': aVal = a.calcDaysLapsed; bVal = b.calcDaysLapsed; break;
          default: aVal = a[sortConfig.key]; bVal = b[sortConfig.key];
        }
        if (aVal < bVal) return sortConfig.direction === 'asc' ? -1 : 1;
        if (aVal > bVal) return sortConfig.direction === 'asc' ? 1 : -1;
        return 0;
      });
    }
    return items;
  }, [computedTasks, searchTerm, selectedStatuses, selectedOwners, selectedUserView, sortConfig]);

  const displayStats = useMemo(() => {
    const counts = sortedAndFilteredTasks.reduce((acc, task) => { acc[task.displayStatus] = (acc[task.displayStatus] || 0) + 1; return acc; }, {});
    const openStatuses = ['on track', 'delayed', 'Hold'];
    const openCount = openStatuses.reduce((sum, s) => sum + (counts[s] || 0), 0);
    const ownerArray = Object.entries(globalOwnerStats).map(([name, data]) => ({ name, ...data }));
    const validLT = ownerArray.filter(o => o.total > 0);
    return { 
      counts, total: sortedAndFilteredTasks.length, 
      avgLeadTime: sortedAndFilteredTasks.length > 0 ? Math.round(sortedAndFilteredTasks.reduce((sum, t) => sum + (t.calcDaysLapsed || 0), 0) / sortedAndFilteredTasks.length) : 0,
      openCount, closedCount: sortedAndFilteredTasks.length - openCount,
      performance: {
        allByClosed: [...ownerArray].sort((a, b) => b.closed - a.closed),
        allByOpen: [...ownerArray].sort((a, b) => b.open - a.open),
        allByShortestLT: [...validLT].sort((a, b) => a.avgLeadTime - b.avgLeadTime),
        allByLongestLT: [...validLT].sort((a, b) => b.avgLeadTime - a.avgLeadTime)
      }
    };
  }, [sortedAndFilteredTasks, globalOwnerStats]);

  const allOwners = useMemo(() => Object.keys(globalOwnerStats).sort(), [globalOwnerStats]);

  // --- 5. CRUD Ops ---
  const handleUpdate = async (id, field, value) => {
    if (!isAdmin || !user) return;
    const docRef = doc(db, 'artifacts', appId, 'public', 'data', 'tasks', String(id));
    const task = tasks.find(t => String(t.id) === String(id));
    if (!task) return;
    try {
      await setDoc(docRef, { ...task, [field]: value, lastUpdate: TODAY_STR }, { merge: true });
    } catch (err) { console.error("Update error:", err); }
  };

  const handleAddTask = async () => {
    if (!isAdmin || !user) return;
    const nextId = tasks.length > 0 ? Math.max(...tasks.map(t => Number(t.id))) + 1 : 1;
    await setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'tasks', String(nextId)), {
      id: String(nextId), item: "New Task", owner: "Assignee", comment: "", status: "on track", assignedDate: TODAY_STR, dueDate: TODAY_STR, finishDate: "", lastUpdate: TODAY_STR
    });
  };

  const handleDeleteTask = async (id) => {
    if (!isAdmin || !user) return;
    await deleteDoc(doc(db, 'artifacts', appId, 'public', 'data', 'tasks', String(id)));
    setDeleteConfirmId(null);
  };

  const handleLogin = () => {
    if (password === "0424") {
      setIsAdmin(true);
      setShowLoginModal(false);
      setPassword("");
    }
  };

  // --- Components ---
  const AccordionCard = ({ title, icon, data, type, categoryId }) => {
    const isExpanded = expandedCategory === categoryId;
    const displayList = isExpanded ? data : data.slice(0, 3);
    const colors = { shortestLT: "bg-emerald-50/50 border-emerald-100 text-emerald-600", longestLT: "bg-red-50/50 border-red-100 text-red-600", closer: "bg-blue-50/50 border-blue-100 text-blue-600", open: "bg-amber-50/50 border-amber-100 text-amber-600" }[type];
    return (
      <div className={`${colors} border p-4 rounded-2xl shadow-sm transition-all flex flex-col h-fit`}>
        <div className="flex items-center justify-between mb-3"><p className="text-[9px] font-black text-slate-500 uppercase flex items-center gap-1">{icon} {title}</p></div>
        <div className={`space-y-1.5 overflow-hidden transition-all duration-500 ${isExpanded ? 'max-h-[400px] overflow-y-auto' : 'max-h-[120px]'}`}>
          {displayList.map((p, i) => (
            <div key={i} className="flex justify-between text-[11px] font-bold text-slate-700 py-1 border-b border-white/40 last:border-0 items-center">
              <span className="flex items-center gap-2"><span className="text-[9px] text-slate-300 w-3">#{i + 1}</span>{p.name}</span>
              <span className="font-black">{type.includes('LT') ? `${p.avgLeadTime}d` : p[type === 'closer' ? 'closed' : 'open']}</span>
            </div>
          ))}
        </div>
        {data.length > 3 && (<button onClick={() => setExpandedCategory(isExpanded ? null : categoryId)} className="mt-4 w-full flex items-center justify-center gap-1.5 py-1.5 rounded-xl text-[9px] font-black uppercase border border-transparent hover:border-slate-200 hover:bg-white text-slate-400">{isExpanded ? <>Close <ChevronUp size={12} /></> : <>Show Rank <ChevronDown size={12} /></>}</button>)}
      </div>
    );
  };

  const EditableField = ({ initialValue, onSave, isAdmin, isTextArea = false, isItem = false }) => {
    const [draft, setDraft] = useState(initialValue || "");
    const [isEditing, setIsEditing] = useState(false);
    useEffect(() => { setDraft(initialValue || ""); }, [initialValue]);

    if (!isAdmin) {
      return isTextArea ? (
        <p className="w-full text-[14px] text-slate-600 font-medium leading-relaxed whitespace-pre-wrap">{initialValue || "No comment."}</p>
      ) : (
        <p className={`text-sm font-bold leading-tight text-slate-800 ${isItem ? 'line-clamp-3 overflow-hidden' : ''}`}>{initialValue}</p>
      );
    }

    const hasChanged = draft !== (initialValue || "");
    // Item의 경우 관리자 모드에서도 3줄까지 볼 수 있도록 textarea를 사용하고 굵은 글씨체 유지
    const isMultiLine = isTextArea || isItem;

    return (
      <div className="relative group w-full flex flex-col gap-2">
        {isMultiLine ? (
          <textarea 
            value={draft} 
            onChange={(e) => { setDraft(e.target.value); setIsEditing(true); }} 
            className={`w-full bg-transparent outline-none resize-none leading-relaxed border-2 border-transparent focus:border-blue-100 rounded-lg p-1 ${isItem ? 'text-sm font-bold text-slate-800' : 'text-[14px] text-slate-700 font-semibold'}`} 
            rows={isItem ? 3 : 3} 
            onFocus={() => setIsEditing(true)} 
          />
        ) : (
          <input 
            type="text" 
            value={draft} 
            onChange={(e) => { setDraft(e.target.value); setIsEditing(true); }} 
            className="w-full text-xs font-bold bg-slate-50 border-2 border-transparent focus:border-blue-100 rounded-xl p-2 outline-none" 
            onFocus={() => setIsEditing(true)} 
          />
        )}
        {isEditing && (
          <div className="flex items-center gap-2">
            <button onClick={() => { onSave(draft); setIsEditing(false); }} className={`px-3 py-1.5 rounded-lg text-[10px] font-black uppercase shadow-sm ${hasChanged ? 'bg-blue-600 text-white' : 'bg-slate-200 text-slate-500'}`} disabled={!hasChanged}><Save size={12} /> Save</button>
            <button onClick={() => { setDraft(initialValue || ""); setIsEditing(false); }} className="px-3 py-1.5 rounded-lg text-[10px] font-black uppercase text-slate-400">Cancel</button>
          </div>
        )}
      </div>
    );
  };

  const SortButton = ({ columnKey, label }) => {
    const isActive = sortConfig.key === columnKey;
    return (
      <button onClick={() => { let dir = 'asc'; if (sortConfig.key === columnKey && sortConfig.direction === 'asc') dir = 'desc'; else if (sortConfig.key === columnKey && sortConfig.direction === 'desc') dir = null; setSortConfig({ key: columnKey, direction: dir }); }} className={`flex items-center gap-1.5 transition-colors group ${isActive ? 'text-blue-600' : 'text-slate-400 hover:text-slate-600'}`}>
        <span className="text-[10px] font-black uppercase tracking-widest">{label}</span>
        {isActive ? (sortConfig.direction === 'asc' ? <ArrowUp size={12} strokeWidth={3} /> : <ArrowDown size={12} strokeWidth={3} />) : (<ArrowUpDown size={12} className="opacity-0 group-hover:opacity-100" />)}
      </button>
    );
  };

  const pieData = useMemo(() => {
    let sa = 0;
    return STATUS_OPTIONS.map(status => {
      const c = displayStats.counts[status] || 0;
      const p = displayStats.total > 0 ? (c / displayStats.total) * 100 : 0;
      const angle = displayStats.total > 0 ? (c / displayStats.total) * 360 : 0;
      const data = p > 0 ? { status, color: getStatusColor(status), count: c, percentage: p.toFixed(1), startAngle: sa, angle } : null;
      sa += angle;
      return data;
    }).filter(Boolean);
  }, [displayStats]);

  return (
    <div className="min-h-screen bg-slate-100 p-6 font-sans text-slate-900 flex flex-col relative pb-16">
      <div className="max-w-[1800px] mx-auto w-full mb-6 flex items-center justify-between">
        <div><h1 className="text-3xl font-black text-slate-800 tracking-tighter mb-1">Sinil Things To Do</h1><p className="text-slate-500 text-sm font-bold uppercase tracking-wider">Cloud Synchronized Dashboard</p></div>
        <div className="flex items-center gap-4">
          {isAdmin && <button onClick={handleAddTask} className="text-xs font-black bg-blue-600 hover:bg-blue-700 text-white px-5 py-2.5 rounded-xl shadow-md flex items-center gap-1.5 transition-all"><Plus size={16} /> Add Task</button>}
          {isAdmin ? <button onClick={() => setIsAdmin(false)} className="text-xs font-black bg-emerald-500 hover:bg-emerald-600 text-white px-5 py-2.5 rounded-xl shadow-md flex items-center gap-1.5 transition-all"><Unlock size={16} /> Admin Active</button> : <button onClick={() => setShowLoginModal(true)} className="text-xs font-black bg-slate-900 hover:bg-slate-800 text-white px-5 py-2.5 rounded-xl shadow-md flex items-center gap-1.5 transition-all"><LogIn size={16} /> Admin Login</button>}
        </div>
      </div>

      {loading ? (
        <div className="flex-1 flex flex-col items-center justify-center py-40">
          <Loader2 size={48} className="animate-spin text-blue-500 mb-4 opacity-50" />
          <p className="text-slate-400 font-black uppercase tracking-widest text-[10px]">Syncing Data...</p>
        </div>
      ) : (
        <>
          {!selectedUserView ? (
            <>
              <div className="max-w-[1800px] mx-auto w-full mb-6 bg-white p-8 rounded-[2rem] shadow-md border border-slate-200/80">
                <div className="flex flex-col lg:flex-row gap-8 items-stretch mb-8">
                  <div className="flex items-center gap-5 lg:pr-8 lg:border-r border-slate-100 flex-shrink-0">
                    <div className="relative w-28 h-28 flex-shrink-0">
                      <svg viewBox="0 0 32 32" className="w-full h-full transform -rotate-90">
                        {pieData.map((slice, i) => {
                          const x = 16 + 16 * Math.cos((slice.startAngle * Math.PI) / 180);
                          const y = 16 + 16 * Math.sin((slice.startAngle * Math.PI) / 180);
                          const endX = 16 + 16 * Math.cos(((slice.startAngle + slice.angle) * Math.PI) / 180);
                          const endY = 16 + 16 * Math.sin(((slice.startAngle + slice.angle) * Math.PI) / 180);
                          return <path key={i} d={`M 16 16 L ${x} ${y} A 16 16 0 ${slice.angle > 180 ? 1 : 0} 1 ${endX} ${endY} Z`} fill={slice.color} className="stroke-white stroke-[1.5]" />;
                        })}
                      </svg>
                      <div className="absolute inset-0 flex items-center justify-center bg-white m-5 rounded-full shadow-inner flex-col"><span className="text-[8px] font-black text-slate-400 uppercase">Total</span><span className="text-sm font-black text-slate-800">{displayStats.total}</span></div>
                    </div>
                    <div className="w-[140px] max-h-[120px] overflow-y-auto pr-2 space-y-2">
                      {pieData.map((slice, i) => (<div key={i} className="flex items-center justify-between group"><div className="flex items-center gap-2"><div className="w-2.5 h-2.5 rounded-full" style={{ backgroundColor: slice.color }}></div><span className="text-[11px] font-bold text-slate-600 uppercase">{slice.status}</span></div><div className="text-right flex items-center gap-1"><span className="text-[11px] font-black text-slate-800">{slice.count}</span><span className="text-[9px] font-bold text-slate-400 w-8 text-right">({slice.percentage}%)</span></div></div>))}
                    </div>
                  </div>
                  <div className="flex-1 grid grid-cols-1 sm:grid-cols-3 gap-5">
                    <div className="bg-emerald-50 p-4 rounded-2xl border border-emerald-100 flex flex-col justify-center text-center shadow-sm"><p className="text-[10px] font-black text-slate-500 uppercase mb-1">Closed Rate</p><p className="text-3xl font-black text-slate-800">{displayStats.total > 0 ? ((displayStats.closedCount / displayStats.total) * 100).toFixed(1) : 0}%</p></div>
                    <div className="bg-purple-50 p-4 rounded-2xl border border-purple-100 flex flex-col justify-center text-center shadow-sm"><p className="text-[10px] font-black text-slate-500 uppercase mb-1">Avg Lead Time</p><p className="text-3xl font-black text-slate-800">{displayStats.avgLeadTime}d</p></div>
                    <div className="bg-slate-50 p-4 rounded-2xl border border-slate-200 flex flex-col justify-center text-center shadow-sm"><p className="text-[10px] font-black text-slate-500 uppercase mb-1">Open Items</p><p className="text-3xl font-black text-slate-800">{displayStats.openCount}</p></div>
                  </div>
                </div>
                <div className="pt-6 border-t border-slate-100 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
                  <AccordionCard title="Fastest LT" icon={<Zap size={10}/>} data={displayStats.performance.allByShortestLT} type="shortestLT" categoryId="shortest" />
                  <AccordionCard title="Slowest LT" icon={<Snail size={10}/>} data={displayStats.performance.allByLongestLT} type="longestLT" categoryId="longest" />
                  <AccordionCard title="Top Closer" icon={<Trophy size={10}/>} data={displayStats.performance.allByClosed} type="closer" categoryId="closer" />
                  <AccordionCard title="Most Open" icon={<Flame size={10}/>} data={displayStats.performance.allByOpen} type="open" categoryId="open" />
                </div>
              </div>

              {/* Filters */}
              <div className="max-w-[1800px] mx-auto w-full mb-6 bg-white shadow-sm border border-slate-200/80 rounded-[2rem] p-5 flex flex-col gap-5">
                <div className="flex flex-col lg:flex-row gap-4 items-center justify-between">
                  <div className="flex flex-col lg:flex-row gap-4 items-center flex-1 w-full">
                    <div className="relative group min-w-[250px] w-full lg:w-auto"><Search className="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400" size={16} /><input type="text" placeholder="Search..." className="w-full pl-10 pr-4 py-2.5 bg-slate-50 rounded-xl border border-slate-100 outline-none text-xs font-bold" value={searchTerm} onChange={(e) => setSearchTerm(e.target.value)} /></div>
                    <div className="flex items-center gap-2 overflow-x-auto no-scrollbar w-full lg:w-auto">{STATUS_OPTIONS.map(status => (<button key={status} onClick={() => setSelectedStatuses(prev => prev.includes(status) ? prev.filter(s => s !== status) : [...prev, status])} className={`px-4 py-2 rounded-xl text-[10px] font-black border transition-all flex items-center gap-2 flex-shrink-0 ${selectedStatuses.includes(status) ? 'bg-slate-800 border-slate-800 text-white' : 'bg-white border-slate-200 text-slate-600'}`}><div className="w-2 h-2 rounded-full" style={{ backgroundColor: getStatusColor(status) }} />{status.toUpperCase()}</button>))}</div>
                  </div>
                  <button onClick={() => {setSelectedStatuses([]); setSelectedOwners([]); setSearchTerm(""); setSortConfig({ key: 'id', direction: 'asc' });}} className="text-[11px] font-black text-red-500 px-4 py-2 hover:bg-red-50 rounded-xl">Reset</button>
                </div>
                <div className="flex items-center gap-4 overflow-x-auto custom-scrollbar pt-4 border-t border-slate-100">
                  <span className="text-[9px] font-black text-slate-400 uppercase flex-shrink-0">Assignee:</span>
                  <div className="flex items-center gap-3">{allOwners.map(owner => (<button key={owner} onClick={() => setSelectedOwners(prev => prev.includes(owner) ? prev.filter(o => o !== owner) : [...prev, owner])} className={`flex flex-col items-start px-4 py-2.5 rounded-2xl border transition-all flex-shrink-0 gap-1.5 ${selectedOwners.includes(owner) ? 'bg-blue-50 border-blue-200 shadow-sm' : 'bg-white border-slate-100'}`}><span className="text-[11px] font-black text-slate-700">{owner}</span><div className="flex items-center gap-2 text-[9px] font-black opacity-80 pt-1.5 w-full border-t border-slate-50"><span className="text-amber-500">{globalOwnerStats[owner]?.open}</span><span className="text-slate-200">|</span><span className="text-emerald-500">{globalOwnerStats[owner]?.closed}</span><span className="text-slate-200">|</span><span className="text-purple-500">{globalOwnerStats[owner]?.avgLeadTime}d</span></div></button>))}</div>
                </div>
              </div>

              {/* Table Container */}
              <div className="max-w-[1800px] mx-auto w-full flex-1 bg-white rounded-[2.5rem] shadow-xl border border-slate-200/60 overflow-hidden flex flex-col">
                <div className="overflow-x-auto custom-scrollbar">
                  <table className="w-full text-left border-collapse table-fixed">
                    <thead className="bg-slate-50/80 backdrop-blur-md sticky top-0 z-30 border-b border-slate-200">
                      <tr>
                        <th className="px-4 py-4 w-14 text-center"><SortButton columnKey="id" label="ID" /></th>
                        <th className="px-4 py-4 text-[10px] font-black text-slate-400 uppercase w-[240px]">Item / Assignee</th>
                        <th className="px-6 py-4 text-[10px] font-black text-slate-400 uppercase flex-1">Latest Status Comment</th>
                        <th className="px-4 py-4 text-[10px] font-black text-slate-400 uppercase w-[115px] text-center">Status</th>
                        <th className="px-3 py-4 w-[125px]"><div className="flex flex-col items-center gap-1"><SortButton columnKey="assignedDate" label="Assign" /><SortButton columnKey="dueDate" label="Due" /></div></th>
                        <th className="px-4 py-4 w-[95px] text-center"><SortButton columnKey="timeline" label="Timeline" /></th>
                        {isAdmin && <th className="px-2 py-4 w-[50px]"></th>}
                      </tr>
                    </thead>
                    <tbody className="divide-y divide-slate-100">
                      {sortedAndFilteredTasks.map((task) => {
                        const isOverdue = getAbsDate(task.dueDate) && getAbsDate(task.dueDate) < TODAY && !["Done", "Canceled", "Failed"].includes(task.displayStatus);
                        const statusStyle = { 'Done': 'bg-emerald-500 text-white', 'on track': 'bg-blue-500 text-white', 'delayed': 'bg-red-500 text-white animate-pulse', 'Hold': 'bg-amber-500 text-white', 'Failed': 'bg-slate-900 text-white line-through', 'Canceled': 'bg-slate-300 text-slate-600' };
                        return (
                          <tr key={task.id} className="group hover:bg-blue-50/30 transition-all">
                            <td className="px-4 py-6 text-xs font-black text-slate-300 text-center">#{task.id}</td>
                            <td className="px-4 py-6"><div className="space-y-3"><EditableField initialValue={task.item} onSave={(val) => handleUpdate(task.id, 'item', val)} isAdmin={isAdmin} isItem={true} /><div className="flex flex-col gap-1.5"><div className="flex items-center gap-1.5 text-[10px] font-black text-slate-400 uppercase"><User size={12} /> Assignee</div><EditableField initialValue={task.owner} onSave={(val) => handleUpdate(task.id, 'owner', val)} isAdmin={isAdmin} /></div></div></td>
                            <td className="px-6 py-6"><div className={`p-5 rounded-[1.5rem] border transition-all ${isAdmin ? 'bg-slate-50 border-slate-100' : 'bg-white border-transparent shadow-sm'}`}><div className="flex items-start gap-4"><div className="mt-1 p-2.5 bg-white rounded-xl shadow-sm text-blue-500 flex-shrink-0"><MessageSquare size={18} /></div><EditableField initialValue={task.comment} onSave={(val) => handleUpdate(task.id, 'comment', val)} isAdmin={isAdmin} isTextArea={true} /></div></div></td>
                            <td className="px-4 py-6 text-center"><div className="flex flex-col items-center justify-center gap-1.5">{isAdmin ? (<select value={task.displayStatus} onChange={(e) => handleUpdate(task.id, 'status', e.target.value)} className={`w-full text-[10px] font-black py-2.5 px-2 rounded-xl text-center uppercase cursor-pointer ${statusStyle[task.displayStatus]}`} style={{ backgroundColor: getStatusColor(task.displayStatus) }}>{STATUS_OPTIONS.map(opt => <option key={opt} value={opt}>{opt.toUpperCase()}</option>)}</select>) : (<div className={`w-full text-[10px] font-black py-2.5 px-2 rounded-xl text-center uppercase shadow-sm ${statusStyle[task.displayStatus]}`} style={{ backgroundColor: getStatusColor(task.displayStatus) }}>{task.displayStatus}</div>)}</div></td>
                            <td className="px-3 py-6"><div className="flex flex-col gap-3"><div className="text-center"><span className="text-[8px] font-bold text-slate-400 uppercase">Assigned</span><div className="text-[10px] font-black px-2 py-1.5 rounded-lg border bg-slate-50 text-slate-600">{formatDisplayDate(task.assignedDate)}</div></div><div className="text-center"><span className="text-[8px] font-bold text-slate-400 uppercase">Due</span><div className={`text-[10px] font-black px-2 py-1.5 rounded-lg border text-center ${isOverdue ? 'bg-red-50 text-red-600 border-red-200' : 'bg-slate-50 text-slate-600 border-slate-100'}`}>{formatDisplayDate(task.dueDate)}</div></div></div></td>
                            <td className="px-4 py-6 text-center"><div className="flex flex-col items-center gap-0.5"><Timer size={14} className="text-slate-400" /><span className="text-[10px] font-black text-slate-600">{task.calcDaysLapsed}d</span></div></td>
                            {isAdmin && <td className="px-2 py-6 text-center"><button onClick={() => setDeleteConfirmId(task.id)} className="p-2 text-slate-200 hover:text-red-500 transition-all"><Trash2 size={18} /></button></td>}
                          </tr>
                        );
                      })}
                    </tbody>
                  </table>
                </div>
              </div>
            </>
          ) : (
             <div className="max-w-[1800px] mx-auto w-full flex flex-col flex-1 animate-in fade-in slide-in-from-bottom-4">
                <button onClick={() => setSelectedUserView(null)} className="mb-6 p-3 bg-white text-slate-500 hover:text-blue-600 rounded-2xl shadow-sm transition-all flex items-center gap-2 text-xs font-black uppercase w-fit"><ArrowLeft size={16} /> Back</button>
                <div className="bg-white p-8 rounded-[2.5rem] shadow-md border border-slate-200/80 mb-6 flex justify-between items-center">
                  <h2 className="text-4xl font-black text-slate-800 tracking-tight">{selectedUserView} Stats</h2>
                  <div className="flex gap-6">
                    <div className="text-center"><p className="text-xs font-black text-slate-500 uppercase">Total</p><p className="text-2xl font-black">{globalOwnerStats[selectedUserView]?.total || 0}</p></div>
                    <div className="text-center"><p className="text-xs font-black text-slate-500 uppercase">Avg LT</p><p className="text-2xl font-black text-purple-600">{globalOwnerStats[selectedUserView]?.avgLeadTime || 0}d</p></div>
                  </div>
                </div>
             </div>
          )}
        </>
      )}

      {/* Admin Login Modal */}
      {showLoginModal && (
        <div className="fixed inset-0 bg-slate-900/60 backdrop-blur-md z-[200] flex items-center justify-center p-4">
          <div className="bg-white rounded-[2.5rem] p-10 max-w-sm w-full shadow-2xl text-center">
            <h2 className="text-2xl font-black mb-6 tracking-tight">Admin Login</h2>
            <input 
              type="password" 
              placeholder="••••" 
              className="w-full px-6 py-4 rounded-2xl border-2 border-slate-100 bg-slate-50 text-center text-2xl tracking-[0.5em] outline-none mb-4 focus:border-blue-400" 
              value={password} 
              onChange={(e) => setPassword(e.target.value)} 
              onKeyDown={(e) => { if (e.key === 'Enter') handleLogin(); }} 
              autoFocus 
            />
            <div className="flex gap-3">
              <button onClick={() => setShowLoginModal(false)} className="flex-1 py-4 rounded-2xl font-bold bg-slate-100 text-slate-500">Cancel</button>
              <button onClick={handleLogin} className="flex-1 py-4 rounded-2xl font-bold text-white bg-blue-600 shadow-lg shadow-blue-200">Login</button>
            </div>
          </div>
        </div>
      )}

      {deleteConfirmId && (
        <div className="fixed inset-0 bg-slate-900/40 z-[200] flex items-center justify-center p-4">
          <div className="bg-white rounded-3xl p-8 max-w-sm w-full shadow-2xl text-center">
            <h2 className="text-xl font-black mb-4">Delete Task #{deleteConfirmId}?</h2>
            <div className="flex gap-3">
              <button onClick={() => setDeleteConfirmId(null)} className="flex-1 py-3 rounded-xl font-bold bg-slate-100 text-slate-500">Cancel</button>
              <button onClick={() => handleDeleteTask(deleteConfirmId)} className="flex-1 py-3 rounded-xl font-bold bg-red-500 text-white">Delete</button>
            </div>
          </div>
        </div>
      )}
      
      <div className="absolute bottom-6 left-0 right-0 pointer-events-none opacity-40"><p className="text-center text-[10px] font-medium text-slate-400 uppercase tracking-widest">Copyright @ Vincent Shin 2026</p></div>
    </div>
  );
};
export default App;
